{
  "name": "crewtrace-landing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:seo": "npm run lint -- scripts/seo lib/__tests__/seo-policy.test.ts lib/__tests__/schema.test.ts",
    "seo:check": "node scripts/seo/check-seo-contract.mjs",
    "seo:check-links": "node scripts/seo/check-internal-links.mjs",
    "seo:check-clusters": "node scripts/seo/check-cluster-content.mjs",
    "seo:check-attribution": "node scripts/seo/check-booked-call-attribution.mjs",
    "seo:check-schema": "node scripts/seo/check-schema-presence.mjs",
    "seo:check-messaging": "node scripts/seo/check-messaging-guardrails.mjs",
    "seo:check:all": "npm run seo:check && npm run seo:check-schema && npm run seo:check-links && npm run seo:check-clusters && npm run seo:check-messaging && npm run seo:check-attribution",
    "seo:report-booked-calls": "node scripts/analytics/export-booked-call-report.mjs",
    "content:check-publish": "node scripts/content/check-ai-publish-gate.mjs --input content/blog"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
